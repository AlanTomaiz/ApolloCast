{
  "name": "apolocast",
  "description": "A beautiful Videostream GUI.",
  "version": "1.0.0",
  "license": "MIT",
  "main": ".webpack/main",
  "author": {
    "name": "Alanderson Tomaiz",
    "email": "alan_tomaiz@hotmail.com",
    "url": "https://github.com/AlanTomaiz/ApolloCast"
  },
  "scripts": {
    "start": "NODE_NO_WARNINGS=1 ELECTRON_DISABLE_GPU=1 LIBGL_DRI3_DISABLE=1 electron-forge start -- --disable-gpu --disable-gpu-sandbox --disable-dev-shm-usage --in-process-gpu --no-sandbox",
    "package": "electron-forge package",
    "make": "node scripts/make-artifact.js",
    "publish": "electron-forge publish",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier . --write",
    "format:check": "prettier . --check"
  },
  "config": {
    "forge": {
      "packagerConfig": {
        "icon": "./src/assets/icon"
      },
      "makers": [
        {
          "name": "@electron-forge/maker-wix",
          "config": {
            "name": "ApolloCast",
            "manufacturer": "Alanderson Tomaiz",
            "icon": "./src/assets/icon.ico",
            "language": 1046,
            "programFilesFolderName": "ApolloCast",
            "shortcutFolderName": "ApolloCast",
            "ui": {
              "chooseDirectory": true
            }
          }
        },
        {
          "name": "@electron-forge/maker-dmg",
          "platforms": [
            "darwin"
          ]
        },
        {
          "name": "@electron-forge/maker-zip",
          "platforms": [
            "darwin",
            "win32"
          ]
        },
        {
          "name": "@electron-forge/maker-deb",
          "config": {}
        }
      ],
      "plugins": [
        [
          "@electron-forge/plugin-webpack",
          {
            "mainConfig": "./webpack.main.config.js",
            "renderer": {
              "config": "./webpack.renderer.config.js",
              "entryPoints": [
                {
                  "html": "./src/index.html",
                  "js": "./src/renderer.ts",
                  "name": "main_window",
                  "preload": {
                    "js": "./src/preload.js"
                  }
                }
              ]
            }
          }
        ]
      ]
    }
  },
  "devDependencies": {
    "@electron-forge/cli": "^6.0.0-beta.63",
    "@electron-forge/maker-deb": "^6.0.0-beta.63",
    "@electron-forge/maker-dmg": "^6.0.0-beta.63",
    "@electron-forge/maker-wix": "6.0.0-beta.63",
    "@electron-forge/maker-zip": "^6.0.0-beta.63",
    "@electron-forge/plugin-webpack": "6.0.0-beta.63",
    "@types/electron": "^1.6.10",
    "@types/react": "^18.0.5",
    "@types/react-dom": "^18.0.1",
    "@typescript-eslint/eslint-plugin": "^6.21.0",
    "@typescript-eslint/parser": "^6.21.0",
    "@vercel/webpack-asset-relocator-loader": "1.7.0",
    "css-loader": "^6.0.0",
    "electron": "18.0.4",
    "eslint": "^8.56.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-prettier": "^5.1.3",
    "fork-ts-checker-webpack-plugin": "^6.0.1",
    "node-loader": "^2.0.0",
    "prettier": "^3.2.5",
    "style-loader": "^3.0.0",
    "ts-loader": "^9.2.2",
    "typescript": "~4.5.4"
  },
  "dependencies": {
    "bonjour": "^3.5.0",
    "castv2-client": "^1.2.0",
    "electron-squirrel-startup": "^1.0.0",
    "path-browserify": "^1.0.1",
    "react": "^18.0.0",
    "react-dom": "^18.0.0",
    "react-icons": "^4.3.1"
  }
}
